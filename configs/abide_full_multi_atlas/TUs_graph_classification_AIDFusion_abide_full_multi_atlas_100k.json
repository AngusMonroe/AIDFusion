{
    "gpu": {
        "use": true,
        "id": 0
    },
    
    "model": "AIDFusion",
    "dataset": "abide_full_multi_atlas",
    "views": ["abide_full_schaefer100", "abide_full_aal116"],
    "out_dir": "out/braindata_graph_classification/",

    "params": {
        "seed": 41,
        "epochs": 1000,
        "batch_size": 51,
        "init_lr": 1e-4,
        "lr_reduce_factor": 0.5,
        "lr_schedule_patience": 25,
        "min_lr": 6e-5,
        "weight_decay": 0.0,
        "print_epoch_interval": 5,
        "max_time": 12
    },
    
    "net_params": {
        "L": 1,
        "hidden_dim": 100,
        "out_dim": 100,
        "residual": true,
        "readout": "mean",
        "in_feat_dropout": 0.0,
        "dropout": 0.0,
        "batch_norm": true,
        "self_loop": false,
        "edge_feat": false,
        "k": 10
    }
}
