{
    "gpu": {
        "use": true,
        "id": 0
    },
    
    "model": "MADT",
    "dataset": "adni_multi_atlas",
    "views": ["adni_schaefer100", "adni_AAL116"],
    "out_dir": "out/braindata_graph_classification/",

    "params": {
        "seed": 41,
        "epochs": 1000,
        "batch_size": 133,
        "init_lr": 8e-5,
        "lr_reduce_factor": 0.5,
        "lr_schedule_patience": 25,
        "min_lr": 6e-5,
        "weight_decay": 0.0,
        "print_epoch_interval": 5,
        "max_time": 12
    },
    
    "net_params": {
        "L": 1,
        "hidden_dim": 100,
        "out_dim": 100,
        "residual": true,
        "readout": "mean",
        "in_feat_dropout": 0.0,
        "dropout": 0.0,
        "batch_norm": true,
        "self_loop": false,
        "edge_feat": false,
        "k": 5
    }
}
